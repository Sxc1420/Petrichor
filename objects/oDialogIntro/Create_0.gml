// Inherit the parent event
event_inherited();


dialog.add(black, "Long long ago… Fairies (the People) used to roam the Earth. Under many different names, they formed trade relationships with humans (Mud People).");
dialog.add(black, "However peace wasn’t meant to last. Centuries ago, war broke out, and even with the limited magic they possessed, the fairies were not able to defeat the Mud People.");
dialog.add(black, "When sheer numbers overwhelmed their kind, the People retreated to the underground, the one place not tainted by the despicable Mud People.");
dialog.add(black, "A teenage criminal mastermind, Artemis Fowl has now rediscovered their existence and hopes to relieve the fairies of their gold… for personal gain. You, as his most trusted Butler, now must venture deep into the Earth’s mantle to relieve at least one fairy of their gold." );
dialog.add(black, "Beware, these are not the fairies from folk or legend, their technology far outpaces that of your own. ");
dialog.add(black, "Your objective: Eliminate all obstacles and retrieve the gold for the heir, Artemis Fowl the II. You will be rewarded handsomely for your efforts. Good luck.");
