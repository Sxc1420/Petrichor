// Inherit the parent event
event_inherited();


dialog.add(fairy, "Butler... We've been following your journey. Tracking your master. Artemis Fowl the II knows no bounds.");
dialog.add(fairy, "We understand you have come for the gold... and that our civilization is at risk even after you have gotten past all our defenses.");
dialog.add(fairy, "All we wanted was peace... to coexist with the Mud People. But alas, it seems even as centuries and eons pass, the struggle will continue.");
dialog.add(fairy, "We may not share the same blood, but we do live on the same planet. We had thought maybe in some distance future we could coexist... however I have realized now this will not be the case");
dialog.add(artemis_thinking, "...Hm.");
dialog.add(artemis_angry, "Go for the main objective. Disregard any other information, and eliminate any distractions. Secure the gold, Butler.");
